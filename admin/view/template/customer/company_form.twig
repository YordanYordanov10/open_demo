{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <style>
        
        #preloader {
            display: none;
            align-items: center;
            justify-content: center;
        }

        .loader-circle {
            border: 4px solid #f3f3f3;
            border-top: 4px solid #3498db;
            border-radius: 50%;
            width: 20px;
            height: 20px;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
      </style>
      <div class="pull-right">
        <div id="preloader"><div class="loader-circle"></div> </div>
        <button type="submit" form="form-company" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
        <button type="button" id="button-api" data-toggle="tooltip" title="{{ button_api }}" class="btn btn-success" ><i class="fa fa-gear"></i></button>
    
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}

    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-pencil"></i> {{ text_form }}</h3>
      </div>
      <div class="panel-body">
        <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-company" class="form-horizontal">
          <div class="form-group required">
            <label class="col-sm-2 control-label" for="input-eik">{{ entry_eik }}</label>
            <div class="col-sm-10">
              <input type="text" name="eik" value="{{ eik }}" placeholder="{{ entry_eik }}" id="input-eik" class="form-control" maxlength="9" {% if eik_readonly %}readonly="readonly"{% endif %} />
              {% if error_eik %}
              <div class="text-danger">{{ error_eik }}</div>
              {% endif %}
            </div>
          </div>

          <div class="form-group required">
            <label class="col-sm-2 control-label" for="input-company">{{ entry_name }}</label>
            <div class="col-sm-10">
              <input type="text" name="company" value="{{ company }}" placeholder="{{ entry_name }}" id="input-company" class="form-control" />
              {% if error_company %}
              <div class="text-danger">{{ error_company }}</div>
              {% endif %}
            </div>
          </div>

          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-city">{{ entry_city }}</label>
            <div class="col-sm-10">
              <input type="text" name="city" value="{{ city }}" placeholder="{{ entry_city }}" id="input-city" class="form-control" />
              {% if error_city %}
              <div class="text-danger">{{ error_city }}</div>
              {% endif %}
            </div>
          </div>

          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-address">{{ entry_address }}</label>
            <div class="col-sm-10">
              <input type="text" name="address" value="{{ address }}" placeholder="{{ entry_address }}" id="input-address" class="form-control" />
              {% if error_address %}
              <div class="text-danger">{{ error_address }}</div>
              {% endif %}
            </div>
          </div>

          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-manager">{{ entry_manager }}</label>
            <div class="col-sm-10">
              <input type="text" name="manager" value="{{ manager }}" placeholder="{{ entry_manager }}" id="input-manager" class="form-control" />
              {% if error_manager %}
              <div class="text-danger">{{ error_manager }}</div>
              {% endif %}
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<script>

  $('#button-api').on('click', function() {

      let preloader = $('#preloader');
      let eikField = $('#input-eik');
     $.ajax({

        url: 'index.php?route=customer/company_api/eik&user_token={{ user_token }}&eik=' + encodeURIComponent(eikField.val()),
        dataType: 'json',

        beforeSend: function(){
            preloader.css('display','flex');
        },

        success: function(json){

            setTimeout(function(){

                preloader.hide();
              
                if(json.error){
                    showNotification(json.error, 'error');
                    $('#input-company').focus();

                    return;
                }
                
                $('#input-company').val(json.name);
                $('#input-city').val(json.city);
                $('#input-address').val(json.address);
                $('#input-manager').val(json.manager);

            }, 500);

        },

        error: function(){

            setTimeout(function(){

                preloader.hide();
                $('#error-eik').text('Грешка при връзка със сървъра.');

            }, 500);

        }

    });
  });
</script>
{{ footer }}
