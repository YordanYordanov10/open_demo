{{ header }}
{{ column_left }}

<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-rule" class="btn btn-primary">
          <i class="fa fa-save"></i> {{ button_save }}
        </button>
        <a href="{{ cancel }}" class="btn btn-default">
          <i class="fa fa-reply"></i> {{ button_cancel }}
        </a>
      </div>
      <h1>{{ heading_title }}</h1>
    </div>
  </div>

  <div class="container-fluid">
    {% if error_warning %}
      <div class="alert alert-danger">
        <i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      </div>
    {% endif %}

    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title">{{ form_heading }}</h3>
      </div>

      <div class="panel-body">
        <form id="form-rule" action="{{ action }}" method="post" class="form-horizontal">

          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_name }}</label>
            <div class="col-sm-10">
              <input type="text" name="name" value="{{ name }}" class="form-control"/>
              {% if error_name %}
                <div class="text-danger">{{ error_name }}</div>
              {% endif %}
            </div>
          </div>

          <hr/>

          <h4>Conditions</h4>
          <div class="panel panel-default">
            <div class="panel-body">
              <button type="button" id="add-condition" class="btn btn-sm btn-primary">
                <i class="fa fa-plus"></i> Add Condition
              </button>

              <div class="table-responsive" style="margin-top:10px;">
                <table id="conditions_table" class="table table-striped table-bordered">
                  <thead>
                    <tr>
                      <th>Type</th>
                      <th>Operator</th>
                      <th>Value</th>
                      <th style="width:1px;"></th>
                    </tr>
                  </thead>
                  <tbody>
                    {% set cond_row = 0 %}
                    {% if conditions %}
                      {% for condition in conditions %}
                        <tr id="condition-row{{ cond_row }}">
                          <td>
                            <select name="conditions[{{ cond_row }}][type]" class="form-control">
                              {% for key, label in condition_types %}
                                <option value="{{ key }}" {% if condition.type == key %} selected {% endif %}>{{ label }}</option>
                              {% endfor %}
                            </select>
                          </td>
                          <td>
                            <select name="conditions[{{ cond_row }}][operator]" class="form-control">
                              {% for key, label in operator_types %}
                                <option value="{{ key }}" {% if condition.operator == key %} selected {% endif %}>{{ label }}</option>
                              {% endfor %}
                            </select>
                          </td>
                          <td>
                            <input type="text" name="conditions[{{ cond_row }}][value]" value="{{ condition.value }}" class="form-control"/>
                          </td>
                          <td>
                            <button type="button" onclick="$('#condition-row{{ cond_row }}').remove();" class="btn btn-danger btn-sm"><i class="fa fa-minus-circle"></i></button>
                          </td>
                        </tr>
                        {% set cond_row = cond_row + 1 %}
                      {% endfor %}
                    {% endif %}
                  </tbody>
                </table>
              </div>
            </div>
          </div>

          <hr/>

          <h4>Actions</h4>
          <div class="panel panel-default">
            <div class="panel-body">
              <button type="button" id="add-action" class="btn btn-sm btn-primary">
                <i class="fa fa-plus"></i> Add Action
              </button>

              {% if error_actions %}
                <div class="text-danger" style="margin-top:10px;">{{ error_actions }}</div>
              {% endif %}

              <div class="table-responsive" style="margin-top:10px;">
                <table id="actions_table" class="table table-striped table-bordered">
                  <thead>
                    <tr>
                      <th>Action Type</th>
                      <th>Value</th>
                      <th style="width:1px;"></th>
                    </tr>
                  </thead>
                  <tbody>
                    {% set act_row = 0 %}
                    {% if actions %}
                      {% for action in actions %}
                        <tr id="action-row{{ act_row }}">
                          <td>
                            <select name="actions[{{ act_row }}][type]" class="form-control">
                              {% for key, label in action_types %}
                                <option value="{{ key }}" {% if action.type == key %} selected {% endif %}>{{ label }}</option>
                              {% endfor %}
                            </select>
                          </td>
                          <td>
                            <input type="text" name="actions[{{ act_row }}][value]" value="{{ action.value }}" class="form-control"/>
                          </td>
                          <td>
                            <button type="button" onclick="$('#action-row{{ act_row }}').remove();" class="btn btn-danger btn-sm"><i class="fa fa-minus-circle"></i></button>
                          </td>
                        </tr>
                        {% set act_row = act_row + 1 %}
                      {% endfor %}
                    {% endif %}
                  </tbody>
                </table>
              </div>
            </div>
          </div>

        </form>
      </div>
    </div>
  </div>
</div>

<script type="text/javascript">
var cond_row = {{ cond_row }};
var act_row = {{ act_row }};

var condition_types = {{ condition_types|json_encode()|raw }};
var operator_types = {{ operator_types|json_encode()|raw }};
var action_types = {{ action_types|json_encode()|raw }};

$('#add-condition').on('click', function() {
    var html = '<tr id="condition-row' + cond_row + '">';
    html += '  <td><select name="conditions[' + cond_row + '][type]" class="form-control">';
    $.each(condition_types, function(key, label) {
        html += '<option value="' + key + '">' + label + '</option>';
    });
    html += '  </select></td>';
    html += '  <td><select name="conditions[' + cond_row + '][operator]" class="form-control">';
    $.each(operator_types, function(key, label) {
        html += '<option value="' + key + '">' + label + '</option>';
    });
    html += '  </select></td>';
    html += '  <td><input type="text" name="conditions[' + cond_row + '][value]" value="" class="form-control" /></td>';
    html += '  <td><button type="button" onclick="$(\'#condition-row' + cond_row + '\').remove();" class="btn btn-danger btn-sm"><i class="fa fa-minus-circle"></i></button></td>';
    html += '</tr>';

    $('#conditions_table tbody').append(html);
    cond_row++;
});

$('#add-action').on('click', function() {
    var html = '<tr id="action-row' + act_row + '">';
    html += '  <td><select name="actions[' + act_row + '][type]" class="form-control">';
    $.each(action_types, function(key, label) {
        html += '<option value="' + key + '">' + label + '</option>';
    });
    html += '  </select></td>';
    html += '  <td><input type="text" name="actions[' + act_row + '][value]" value="" class="form-control" /></td>';
    html += '  <td><button type="button" onclick="$(\'#action-row' + act_row + '\').remove();" class="btn btn-danger btn-sm"><i class="fa fa-minus-circle"></i></button></td>';
    html += '</tr>';

    $('#actions_table tbody').append(html);
    act_row++;
});
</script>
{{ footer }}