{{ header }}{{ column_left }}

<div id="content">
	<div class="page-header">
		<div class="container-fluid">
			<h1>{{ heading_title }}</h1>

			<ul class="breadcrumb">
				{% for breadcrumb in breadcrumbs %}
					<li>
						<a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a>
					</li>
				{% endfor %}
			</ul>
		</div>
	</div>


	<div
		class="container-fluid">

		<!-- STAT CARDS -->

		<div class="row">

			<div class="col-lg-3 col-md-3 col-sm-6">
				<div class="panel panel-primary">
					<div class="panel-body text-center">
						<h4>Orders Today</h4>
						<h2>{{ orders_today }}</h2>
					</div>
				</div>
			</div>

			<div class="col-lg-3 col-md-3 col-sm-6">
				<div class="panel panel-success">
					<div class="panel-body text-center">
						<h4>Orders This Month</h4>
						<h2>{{ orders_month }}</h2>
					</div>
				</div>
			</div>

			<div class="col-lg-3 col-md-3 col-sm-6">
				<div class="panel panel-info">
					<div class="panel-body text-center">
						<h4>Average Orders Per Day for the Month</h4>
						<h2>{{ average_orders }}</h2>
					</div>
				</div>
			</div>

			<div class="col-lg-3 col-md-3 col-sm-6">
				<div class="panel panel-warning">
					<div class="panel-body text-center">
						<h4>Average Order Value</h4>
						<h2>{{ average_order_value }}</h2>
					</div>
				</div>
			</div>

		</div>


		<!-- TABLE -->

		<div class="panel panel-default">

			<div class="panel-heading">
				<h3 class="panel-title">
					<i class="fa fa-bar-chart"></i>
					Profit Breakdown
				</h3>
			</div>

			<div class="panel-body">

				<div class="table-responsive">

					<table class="table table-striped table-bordered">

						<thead>
							<tr>
								<th>Metric</th>
								<th class="text-right">Today</th>
								<th class="text-right">This Week</th>
								<th class="text-right">This Month</th>
								<th class="text-right">This Year</th>
								<th class="text-right">Total</th>
							</tr>
						</thead>

						<tbody>

                            <tr>
								<td>Orders</td>
								<td class="text-right">{{ orders_today }}</td>
								<td class="text-right">{{ orders_week }}</td>
								<td class="text-right">{{ orders_month }}</td>
								<td class="text-right">{{ orders_year }}</td>
								<td class="text-right">{{ orders_total }}</td>
							</tr>

							<tr>
								<td>Revenue</td>
								<td class="text-right">{{ revenue_today }}</td>
								<td class="text-right">{{ revenue_week }}</td>
								<td class="text-right">{{ revenue_month }}</td>
								<td class="text-right">{{ revenue_year }}</td>
								<td class="text-right">{{ revenue_total }}</td>
							</tr>

							<tr>
								<td>Average order value</td>
								<td class="text-right">{{ average_order_value_today }}</td>
								<td class="text-right">{{ average_order_value_week }}</td>
								<td class="text-right">{{ average_order_value_month }}</td>
								<td class="text-right">{{ average_order_value_year }}</td>
								<td class="text-right">{{ average_order_value_total }}</td>
							</tr>

                            
							<tr>
								<td>Items Sold</td>
								<td class="text-right">{{ items_sold_today }}</td>
								<td class="text-right">{{ items_sold_week }}</td>
								<td class="text-right">{{ items_sold_month }}</td>
								<td class="text-right">{{ items_sold_year }}</td>
								<td class="text-right">{{ items_sold_total }}</td>
							</tr>

                          
						</tbody>

					</table>

                    <div class="table-responsive">

					<table class="table table-striped table-bordered">

						<thead>
							<tr>
								<th>Status</th>
								<th class="text-right">Today</th>
								<th class="text-right">This Month</th>
								<th class="text-right">Total</th>
							</tr>
						</thead>

						<tbody>

                            <tr>
								<td>Pending</td>
								<td class="text-right">{{ orders_pending_today }}</td>
								<td class="text-right">{{ orders_pending_month }}</td>
								<td class="text-right">{{ orders_pending_total }}</td>
							</tr>

							<tr>
								<td>Processing</td>
								<td class="text-right">{{ orders_processing_today }}</td>
								<td class="text-right">{{ orders_processing_month }}</td>
								<td class="text-right">{{ orders_processing_total }}</td>
							</tr>

							<tr>
								<td>Completed</td>
								<td class="text-right">{{ orders_completed_today }}</td>
								<td class="text-right">{{ orders_completed_month }}</td>
								<td class="text-right">{{ orders_completed_total }}</td>
							</tr>

                            
							<tr>
								<td>Cancelled</td>
								<td class="text-right">{{ orders_cancelled_today }}</td>
								<td class="text-right">{{ orders_cancelled_month }}</td>
								<td class="text-right">{{ orders_cancelled_total }}</td>
							</tr>

                            <tr>
                                <td>Refunded</td>
                                <td class="text-right">{{ orders_refunded_today }}</td>
                                <td class="text-right">{{ orders_refunded_month }}</td>
                                <td class="text-right">{{ orders_refunded_total }}</td>
                            </tr>


                          
						</tbody>

					</table>

				</div>

					{# Chart #}
				<div class="panel panel-default">
					<div class="panel-heading">
						<h3 class="panel-title">
							<i class="fa fa-line-chart"></i>
							Revenue and Profit last 30 days
						</h3>
					</div>

					<div class="panel-body">
						<canvas id="statsChart" height="120"></canvas>
					</div>
				</div>

			</div>

		</div>

	</div>

</div>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script src="view/javascript/initStatChart.js"></script>

<script>
    initStatsChart(
        'statsChart', 
        {{ stats.chart.labels|json_encode|raw }},
        {{ stats.chart.data|json_encode|raw }},
        {{ stats.chart.profit|json_encode|raw }},
        {{ stats.chart.orders|json_encode|raw }},
         {{ stats.chart.margin|json_encode|raw }}
    );
</script>
{{ footer }}
