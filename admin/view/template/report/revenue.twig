{{ header }}{{ column_left }}

<div id="content">
	<div class="page-header">
		<div class="container-fluid">
			<h1>{{ heading_title }}</h1>

			<ul class="breadcrumb">
				{% for breadcrumb in breadcrumbs %}
					<li>
						<a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a>
					</li>
				{% endfor %}
			</ul>
		</div>
	</div>


	<div
		class="container-fluid">

		<!-- STAT CARDS -->

		<div class="row">

			<div class="col-lg-3 col-md-3 col-sm-6">
				<div class="panel panel-primary">
					<div class="panel-body text-center">
						<h4>Revenue Today</h4>
						<h2>{{ revenue_today }}</h2>
					</div>
				</div>
			</div>

			<div class="col-lg-3 col-md-3 col-sm-6">
				<div class="panel panel-success">
					<div class="panel-body text-center">
						<h4>Revenue Month</h4>
						<h2>{{ revenue_month }}</h2>
					</div>
				</div>
			</div>

			<div class="col-lg-3 col-md-3 col-sm-6">
				<div class="panel panel-info">
					<div class="panel-body text-center">
						<h4>Orders</h4>
						<h2>{{ orders_total }}</h2>
					</div>
				</div>
			</div>

			<div class="col-lg-3 col-md-3 col-sm-6">
				<div class="panel panel-warning">
					<div class="panel-body text-center">
						<h4>Average Order Value</h4>
						<h2>{{ average_total }}</h2>
					</div>
				</div>
			</div>

		</div>


		<!-- TABLE -->

		<div class="panel panel-default">

			<div class="panel-heading">
				<h3 class="panel-title">
					<i class="fa fa-bar-chart"></i>
					Revenue Breakdown
				</h3>
			</div>

			<div class="panel-body">

				<div class="table-responsive">

					<table class="table table-striped table-bordered">

						<thead>
							<tr>
								<th>Metric</th>
								<th class="text-right">Today</th>
								<th class="text-right">This Week</th>
								<th class="text-right">This Month</th>
								<th class="text-right">This Year</th>
								<th class="text-right">Total</th>
							</tr>
						</thead>

						<tbody>

							<tr>
								<td>Revenue</td>
								<td class="text-right">{{ revenue_today }}</td>
								<td class="text-right">{{ revenue_week }}</td>
								<td class="text-right">{{ revenue_month }}</td>
								<td class="text-right">{{ revenue_year }}</td>
								<td class="text-right">{{ revenue_total }}</td>
							</tr>

							<tr>
								<td>Average</td>
								<td class="text-right">{{ average_today }}</td>
								<td class="text-right">{{ average_week }}</td>
								<td class="text-right">{{ average_month }}</td>
								<td class="text-right">{{ average_year }}</td>
								<td class="text-right">{{ average_total }}</td>
							</tr>

							<tr>
								<td>Orders</td>
								<td class="text-right">{{ orders_today }}</td>
								<td class="text-right">{{ orders_week }}</td>
								<td class="text-right">{{ orders_month }}</td>
								<td class="text-right">{{ orders_year }}</td>
								<td class="text-right">{{ orders_total }}</td>
							</tr>

							<tr>
								<td>
									<strong>Net Revenue</strong>
								</td>
								<td class="text-right text-success">
									<strong>{{ net_today }}</strong>
								</td>
								<td class="text-right text-success">
									<strong>{{ net_week }}</strong>
								</td>
								<td class="text-right text-success">
									<strong>{{ net_month }}</strong>
								</td>
								<td class="text-right text-success">
									<strong>{{ net_year }}</strong>
								</td>
								<td class="text-right text-success">
									<strong>{{ net_total }}</strong>
								</td>
							</tr>

						</tbody>

					</table>

				</div>

				{# Chart #}
				<div class="panel panel-default">
					<div class="panel-heading">
						<h3 class="panel-title">
							<i class="fa fa-line-chart"></i>
							Revenue and Profit last 30 days
						</h3>
					</div>

					<div class="panel-body">
						<canvas id="statsChart" height="120"></canvas>
					</div>
				</div>

			</div>

		</div>

	</div>

</div>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script src="view/javascript/initStatChart.js"></script>

<script>
    initStatsChart(
        'statsChart', 
        {{ stats.chart.labels|json_encode|raw }},
        {{ stats.chart.data|json_encode|raw }},
        {{ stats.chart.profit|json_encode|raw }},
        {{ stats.chart.orders|json_encode|raw }},
		{{ stats.chart.margin|json_encode|raw }}
    );
</script>
{{ footer }}
