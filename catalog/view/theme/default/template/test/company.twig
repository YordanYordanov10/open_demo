
{{ header }}
<div class="container">

    <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
    </ul>

    <div class="row">

        {{ column_left }}

        {% if column_left and column_right %}
            {% set class = 'col-sm-6' %}
        {% elseif column_left or column_right %}
            {% set class = 'col-sm-9' %}
        {% else %}
            {% set class = 'col-sm-12' %}
        {% endif %}

        <div id="content" class="{{ class }}">

<style>
.form-group {
    margin-bottom: 15px;
    display: flex;
    flex-direction: column;
    max-width: 400px;
}

label {
    font-weight: bold;
    margin-bottom: 5px;
}

input {
    padding: 8px;
    border: 1px solid #ccc;
    border-radius: 4px;
}

.search-section {
    margin-bottom: 30px;
    padding-bottom: 20px;
    border-bottom: 1px solid #eee;
}

#company-details {
    position: relative;
    min-height: 200px;
}

#preloader {
    display: none;
    position: absolute;
    inset: 0;

    /* display: flex; */
    align-items: center;
    justify-content: center;

    background: rgba(255,255,255,0.6);
    z-index: 10;
}

.loader-circle {
    border: 15px solid #f3f3f3;
    border-top: 15px solid #116066;
    border-radius: 50%;
    width: 140px;
    height: 140px;
    animation: spin 2s linear infinite;
}

@keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}

.inputicon {
    position: relative;
    max-width: 400px; 
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
}

.inputicon i {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%); 
    color: #888;
    pointer-events: none; 
}

.inputicon input {
    padding-left: 35px !important; 
     padding-right: 35px !important;
}

.is-valid {
    border-color: #28a745 !important;
    background-color: #f8fff9; /* Леко зелен фон за акцент */
}

#homepage-search-no-results {
    display: none;
    margin-top: 6px;

    width: 100%;              
    max-width: 400px;       

    padding: 8px 10px;
    border-radius: 4px;

    background: #ffffff;     
    color: #888;             
    border: 1px solid #ddd;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    font-size: 12px;
}
/* Когато ЕИК е валиден, можем да сменим цвета на съобщението на зелено */
#homepage-search-no-results.success-msg {
    background-color: #d4edda;
    color: #155724;
    border-color: #c3e6cb;
}



</style>


<h2>Тест Company API</h2>
<div id="alert-container" style="position: fixed; top: 20px; right: 20px; z-index: 9999; min-width: 300px;"></div>

<form id="company-form" method="post" accept-charset="UTF-8">
<div class="search-section">

    <label for="eik">Търсене по ЕИК:</label>

    <div class="inputicon" style="display:flex; align-items:center; gap:10px;">

        <input type="text" id="eik" name="eik" placeholder="Въведете ЕИК..." maxlength="20" autocomplete="off" class="form-control">
     <i class="fa fa-search" style="font-size:18px; color:#888;"></i>
     <i class="fa fa-check success-tick" style="font-size:16px; color: #28a745; position: absolute; left: 370px; display: none;"></i>
    </div>
    <input type="hidden" id="eik_token" name="eik_token" value="{{ eik_token }}">
    

    <!-- Honeypot -->
    <div style="display:none;">
        <input type="text" id="subject_line" name="subject_line" tabindex="-1" autocomplete="off">
    </div>
    <div id="homepage-search-no-results" class="p-4 text-center text-gray-500 text-sm"> Няма намерени резултати </div>
    {# <span id="error-eik" style="color:red;font-size:12px;margin-top:5px;display:block;min-height:15px;"></span> #}

</div>


<div id="company-details">
     <div id="preloader"><div class="loader-circle"></div> </div>
    
    <div class="form-group">
        <label>Име на фирмата:</label>
        <input type="text" id="company" name="company" placeholder="Фирма" class="form-control">
      <span id="error-company"  class="text-danger" style="color:red; font-size:12px;"></span>
    </div>

    <div class="form-group">
        <label>Град:</label>
        <input type="text" id="city" name="city" placeholder="Град" class="form-control">
        <span id="error-city" class="text-danger" style="color:red; font-size:12px;"></span>
    </div>
    <div class="form-group">
        <label>Адрес:</label>
        <input type="text" id="address" name="address" placeholder="Адрес" class="form-control">
        <span id="error-address" class="text-danger" style="color:red; font-size:12px;"></span>
    </div>

    <div class="form-group">
        <label>Управител:</label>
        <input type="text" id="manager" name="manager" placeholder="Управител" class="form-control">
        <span id="error-manager" class="text-danger" style="color:red; font-size:12px;"></span>
    </div>

</div>
</form>

{# Submit button #}
<div style="margin-top:20px;">
    <button type="button" id="submit-btn" class="btn btn-primary">Изпрати</button>
</div>

<script>

let lastLoadedEik = '';
let eikTimer = null;

$('#eik').on('input', function(){

    let raw = $(this).val();
    let eik = normalizeEik(raw);

    clearTimeout(eikTimer);

    $('#error-eik').text('');
    $('#eik').css('border-color','#ccc');

    if (/[^0-9\s|bg|BG|\-]/.test(raw)) {
        $('#error-eik').text('Позволени са само цифри, интервали и "BG" отпред');
        $('#eik').css('border-color', 'red');
        return; // СТОП - не продължаваме към API-то
    }

    if(eik.length === 9){

        if(validateEik(eik)){

            eikTimer = setTimeout(function(){
                loadCompany(eik);
            },300);

        }else{
            
            $('#error-eik').text('Невалиден ЕИК / БУЛСТАТ');
            $('#eik').css('border-color','red');

            $('#homepage-search-no-results')
            .removeClass('success-msg')
            .text('Няма намерени резултати.')
            .fadeIn();
    

        }

    }

    else if(eik.length > 9) {
        $('#error-eik').text('ЕИК трябва да бъде точно 9 цифри (въвели сте ' + eik.length + ')');
        $('#eik').css('border-color','red');
       
    }

    else {

    $('#company, #city, #address, #manager').val('');
    eikTimer = setTimeout(function(){
                loadCompany(eik);
            },300);


    $('#eik').removeClass('is-valid');
    $('.success-tick').hide();

    // Скриваме съобщението ако ЕИК не е 9 цифри
    $('#homepage-search-no-results').hide();
    }
});

function normalizeEik(value){

    if(!value) return '';

    value = value.trim();
    
    value = value.replace(/^bg/i,''); 
    value = value.replace(/\D/g, '');    

    return value;
}

function validateEik(eik){

    if(!/^\d{9}$/.test(eik)){
        return false;
    }

    let weights1 = [1,2,3,4,5,6,7,8];
    let sum = 0;

    for(let i=0;i<8;i++){
        sum += parseInt(eik[i]) * weights1[i];
    }

    let remainder = sum % 11;

    if(remainder < 10){
        return remainder === parseInt(eik[8]);
    }

    let weights2 = [3,4,5,6,7,8,9,10];
    sum = 0;

    for(let i=0;i<8;i++){
        sum += parseInt(eik[i]) * weights2[i];
    }

    remainder = sum % 11;

    if(remainder === 10){
        remainder = 0;
    }

    return remainder === parseInt(eik[8]);
}


function showNotification(message, type = 'success') {
    const color = (type === 'success') ? '#d4edda' : '#f8d7da';
    const textColor = (type === 'success') ? '#155724' : '#dd4b59';
    const borderColor = (type === 'success') ? '#c3e6cb' : '#f5c6cb';

    const html = `
        <div class="alert-box" style="background:${color}; color:${textColor}; border:1px solid ${borderColor}; padding:15px; border-radius:5px; margin-bottom:10px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); transition: opacity 0.5s ease;">
            <strong>${type === 'success' ? 'Успех!' : 'Грешка!'}</strong> ${message}
        </div>
    `;

    const $msg = $(html).appendTo('#alert-container');

  
    setTimeout(function() {
        $msg.css('opacity', '0'); // Fade out effect
        setTimeout(function() { $msg.remove(); }, 500); 
    }, 3000);
}



function loadCompany(eik){
     let eikField = $('#eik');
     let preloader = $('#preloader');

    // Ако е същият, не прави нищо
    if (eik === lastLoadedEik){
        eikField.addClass('is-valid'); 
        $('.success-tick').fadeIn();
                return;
    } 

    $.ajax({

        url: 'index.php?route=test/company/eik&eik_token=' + encodeURIComponent($('#eik_token').val()) + '&eik=' + encodeURIComponent(eik),
        dataType: 'json',

        beforeSend: function(){

            preloader.css('display','flex');
            eikField.prop('readonly', true);
        },

        success: function(json){
            lastLoadedEik = eik;

            setTimeout(function(){

                preloader.hide();
                eikField.prop('readonly', false);

                if(json.error){
                    eikField.removeClass('is-valid');
                    $('.success-tick').hide();

                    showNotification('Фирмата не беше намерена. Можете да въведете данните ръчно.', 'error');
                    // $('#company').focus();

                    return;

                }
                eikField.addClass('is-valid'); 
                $('.success-tick').fadeIn();

                $('#company,#city,#address,#manager').val('');

                $('#company').val(json.name);
                $('#city').val(json.city);
                $('#address').val(json.address);
                $('#manager').val(json.manager);

            }, 500);

        },

        error: function(){

            setTimeout(function(){

                preloader.hide();
                eikField.prop('readonly', false);
                $('#error-eik').text('Грешка при връзка със сървъра.');

            }, 500);

        }

    });

}

$('#submit-btn').on('click', function() {
    $.ajax({
        url: 'index.php?route=test/company/submit&eik_token=' + encodeURIComponent($('#eik_token').val()),
       
       type: 'post',
       dataType: 'json',
       
       data: {
            eik: $('#eik').val(),
            company: $('#company').val(),
            city: $('#city').val(),
            address: $('#address').val(),
            manager: $('#manager').val(),
            token: $('#eik_token').val(),
            subject_line: $('#subject_line').val()
        },
        success: function(json) {
            // 1. Clear old errors
            $('.text-danger').text(''); 
            $('.form-control').css('border-color', '#ccc');

            // 2. Handle Validation Errors
            if (json.errors) {
                $.each(json.errors, function (key, message) {

                    $('#error-' + key).text(message);
                    $('#' + key).css('border-color', 'red');

                });
                 if (typeof showNotification === "function") {
                    showNotification('Моля, попълнете правилно всички полета.', 'error');
                }
            }

            // 3. Handle Success
            if (json.success) {
                if (typeof showNotification === "function") {
                    showNotification(json.success, 'success');
                }
                
                // Clear the form
                $('#company-form')[0].reset();
            }
        }, // <-- This was the comma causing the issue earlier
        error: function(xhr, ajaxOptions, thrownError) {
            if (typeof showNotification === "function") {
                showNotification('Грешка при изпращане на данните. Моля, опитайте отново.', 'error');
            }
            console.log(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
        }
    });
});


</script>

        </div>

        {{ column_right }}

    </div>

</div>

{{ footer }}