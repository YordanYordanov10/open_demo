<div class="modal-header">
	<button type="button" class="close" data-dismiss="modal">&times;</button>
	<h4 class="modal-title">{{ name }}</h4>
</div>
<div class="modal-body">
	<div class="row">
		{% if thumb %}
		<div class="col-sm-5 text-center">
			<img src="{{ thumb }}" alt="{{ name }}" title="{{ name }}" class="img-responsive" style="margin: 0 auto;" />
		</div>
		<div class="col-sm-7">
		{% else %}
		<div class="col-sm-12">
		{% endif %}
			{% if price %}
			<p class="price">
				{% if special %}
				<span class="price-new">{{ special }}</span> <span class="price-old">{{ price }}</span>
				{% else %}
				{{ price }}
				{% endif %}
			</p>
			{% endif %}
			<div style="max-height: 220px; overflow: auto; margin-bottom: 15px;">
				{{ description }}
			</div>
		</div>
	</div>
</div>
<div class="modal-footer">
	<button type="button" class="btn btn-primary" onclick="cart.add('{{ product_id }}', '{{ minimum }}');">{{ button_cart }}</button>
    <button type="button" class="btn btn-danger" onclick="location.href='{{ href }}';">Product details</button>
	<button type="button" class="btn btn-default" data-dismiss="modal">Close</button>
</div>
