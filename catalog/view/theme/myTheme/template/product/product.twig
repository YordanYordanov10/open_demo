{{ header }}

<div id="product-product" class="min-h-screen bg-slate-50 pb-20">
    <div class="bg-white border-b border-slate-200/70 py-4">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
            <nav aria-label="breadcrumb">
                <ul class="flex flex-wrap items-center gap-x-3 text-xs text-slate-500 font-bold uppercase tracking-widest">
                    {% for breadcrumb in breadcrumbs %}
                    <li class="flex items-center gap-3">
                        {% if not loop.last %}
                        <a href="{{ breadcrumb.href }}" class="transition-colors hover:text-sky-600">{{ breadcrumb.text }}</a>
                        <span class="text-slate-300">/</span>
                        {% else %}
                        <span class="text-slate-900">{{ breadcrumb.text }}</span>
                        {% endif %}
                    </li>
                    {% endfor %}
                </ul>
            </nav>
        </div>
    </div>

    <div class="mx-auto max-w-7xl px-4 pt-8 sm:px-6 lg:px-8">
        <div class="flex flex-col gap-10 lg:flex-row items-start">
            
            <div class="w-full lg:w-1/2 shrink-0">
                <div class="sticky top-6 space-y-4">
                    {% if thumb or images %}
                    <div class="group relative overflow-hidden rounded-[2.5rem] border border-white bg-white p-4 shadow-[0_30px_60px_-20px_rgba(0,0,0,0.1)]">
                        {% if thumb %}
                        <a href="{{ popup }}" title="{{ heading_title }}" class="main-image block aspect-square">
                            <img src="{{ thumb }}" title="{{ heading_title }}" alt="{{ heading_title }}" class="h-full w-full object-contain transition-transform duration-700 group-hover:scale-105" id="image-main" />
                        </a>
                        {% endif %}
                    </div>
                    
                    {% if images %}
                    <div class="flex gap-4 overflow-x-auto pb-4 scrollbar-hide">
                        {% for image in images %}
                        <a href="{{ image.popup }}" class="block h-24 w-24 shrink-0 overflow-hidden rounded-2xl border-2 border-transparent bg-white p-2 shadow-sm transition-all hover:border-sky-500" onclick="$('#image-main').attr('src', '{{ image.thumb }}'); return false;">
                            <img src="{{ image.thumb }}" class="h-full w-full object-contain" />
                        </a>
                        {% endfor %}
                    </div>
                    {% endif %}
                    {% endif %}
                </div>
            </div>

            <div class="w-full lg:flex-1">
                <div class="rounded-[2.5rem] border border-white/70 bg-white/40 p-8 shadow-sm backdrop-blur-md lg:p-10">
                    
                    <div class="mb-6">
                        <p class="mb-2 text-[11px] font-black uppercase tracking-[0.3em] text-sky-600">Product details</p>
                        <h1 class="text-3xl font-black tracking-tight text-slate-900 sm:text-4xl lg:text-5xl">{{ heading_title }}</h1>
                    </div>

                    <div class="mb-8 flex items-center gap-4">
                        {% if not special %}
                        <span class="text-4xl font-black tracking-tighter text-slate-950">{{ price }}</span>
                        {% else %}
                        <div class="flex flex-col">
                            <span class="text-sm font-bold text-slate-400 line-through">{{ price }}</span>
                            <span class="text-4xl font-black tracking-tighter text-rose-500">{{ special }}</span>
                        </div>
                        <span class="rounded-full bg-rose-100 px-3 py-1 text-[10px] font-black uppercase tracking-widest text-rose-600">Promotion</span>
                        {% endif %}
                    </div>

                    <hr class="mb-8 border-slate-200/50" />

                    <div id="product" class="space-y-8">
                        {% if options %}
                        <div class="grid gap-6">
                            {% for option in options %}
                            <div class="form-group">
                                <label class="mb-3 block text-[10px] font-black uppercase tracking-widest text-slate-400">{{ option.name }}</label>
                                <select name="option[{{ option.product_option_id }}]" class="w-full rounded-2xl border-slate-200 bg-white py-3 pl-4 text-sm font-bold text-slate-900 focus:border-sky-500 focus:ring-sky-500">
                                    <option value=""> --- Please Select --- </option>
                                    {% for option_value in option.product_option_value %}
                                    <option value="{{ option_value.product_option_value_id }}">{{ option_value.name }} {% if option_value.price %}({{ option_value.price_prefix }}{{ option_value.price }}){% endif %}</option>
                                    {% endfor %}
                                </select>
                            </div>
                            {% endfor %}
                        </div>
                        {% endif %}

                        <div class="flex flex-col gap-4 sm:flex-row sm:items-center">
                            <div class="flex h-14 items-center rounded-2xl border border-slate-200 bg-white p-1 transition-all focus-within:border-sky-500 focus-within:ring-4 focus-within:ring-sky-500/10">
                                <button type="button" onclick="let i = document.getElementById('input-quantity'); if(i.value > 1) i.value--;" class="flex h-12 w-12 items-center justify-center text-slate-400 hover:text-sky-600">
                                    <i class="fa fa-minus"></i>
                                </button>
                                <input type="text" name="quantity" value="{{ minimum }}" id="input-quantity" class="w-12 border-none bg-transparent text-center text-lg font-black text-slate-900 focus:ring-0" />
                                <input type="hidden" name="product_id" value="{{ product_id }}" />
                                <button type="button" onclick="let i = document.getElementById('input-quantity'); i.value++;" class="flex h-12 w-12 items-center justify-center text-slate-400 hover:text-sky-600">
                                    <i class="fa fa-plus"></i>
                                </button>
                            </div>

                            <button type="button" id="button-cart" data-loading-text="{{ text_loading }}" class="flex h-14 flex-1 items-center justify-center gap-3 rounded-2xl bg-slate-950 px-8 text-xs font-black uppercase tracking-[0.2em] text-white transition-all hover:bg-sky-600 hover:-translate-y-1 shadow-xl shadow-slate-200 active:scale-95">
                                <i class="fa fa-shopping-basket text-lg"></i>
                                {{ button_cart }}
                            </button>
                        </div>
                    </div>

                    <div class="mt-10 grid grid-cols-2 gap-4">
                        <div class="rounded-2xl border border-slate-100 bg-white/50 p-4">
                            <p class="text-[9px] font-black uppercase tracking-widest text-slate-400">Model</p>
                            <p class="text-sm font-bold text-slate-700">{{ model }}</p>
                        </div>
                        <div class="rounded-2xl border border-slate-100 bg-white/50 p-4">
                            <p class="text-[9px] font-black uppercase tracking-widest text-slate-400">Stock Status</p>
                            <p class="text-sm font-bold text-sky-600">{{ stock }}</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-16">
            <div class="mb-8 flex border-b border-slate-200">
                <button class="border-b-2 border-sky-600 pb-4 text-sm font-black uppercase tracking-widest text-slate-900">
                    {{ tab_description }}
                </button>
            </div>
            <div class="prose prose-slate max-w-none prose-h2:text-2xl prose-h2:font-black prose-p:text-slate-600">
                {{ description }}
            </div>
        </div>
    </div>
</div>

<script type="text/javascript"></script>

<style>
/* Премахваме скролбара на галерията */
.scrollbar-hide::-webkit-scrollbar { display: none; }
.scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }

/* Typography */
.prose h2, .prose h3 { color: #0f172a !important; font-weight: 900 !important; }
</style>

{{ footer }}