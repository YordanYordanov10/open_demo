{# Checkout Template with Tailwind CSS and Alpine.js #}
{#
Focus is onepage layout like checkout in OC4 with Tailwind CSS and Alpine.js #}

{{ header }}
  <div id="checkout" class="container mx-auto p-4">
    <h1 class="text-2xl font-bold mb-4">{{ heading_title }}</h1>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {% if register or payment_address or shipping_address %}
        <div>
          {% if register %}
            <div id="checkout-register" class="mb-4">{{ register }}</div>
          {% endif %}
          {% if payment_address %}
            <div id="checkout-payment-address" class="mb-4">{{ payment_address }}</div>
          {% endif %}
          {% if shipping_address %}
            <div id="checkout-shipping-address" class="mb-4">{{ shipping_address }}</div>
          {% endif %}
        </div>
      {% endif %}
      <div>
        {% if shipping_method %}
          <div id="checkout-shipping-method" class="mb-4">{{ shipping_method }}</div>
        {% endif %}
        <div id="checkout-payment-method" class="mb-4">{{ payment_method }}</div>
        <div id="checkout-confirm">{{ confirm }}</div>
      </div>
    </div>
    {{ content_bottom }}
  </div>
  {{ column_right }}
</div>


{{ footer }}


