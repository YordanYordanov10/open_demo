{{ header }}

<div class="container mx-auto px-4">
    <nav class="bg-transparent py-4 mb-6">
        <ul class="flex items-center gap-2 text-sm list-none p-0 m-0">
            {% for breadcrumb in breadcrumbs %}
            <li class="flex items-center gap-2">
                {% if not loop.last %}
                    <a href="{{ breadcrumb.href }}" class="text-blue-600 hover:text-blue-800 transition-colors font-medium">
                        {{ breadcrumb.text }}
                    </a>
                    <span class="text-gray-300">
                        <i class="fa fa-angle-right text-[10px]"></i>
                    </span>
                {% else %}
                    <span class="text-gray-400">
                        {{ breadcrumb.text }}
                    </span>
                {% endif %}
            </li>
            {% endfor %}
        </ul>
    </nav>
</div>

    <div class="container mx-auto px-4">
        <div class="flex flex-col lg:flex-row gap-8">
            
            {{ column_left }}

            <div id="content" class="flex-1">
                <div class="bg-white rounded-3xl shadow-xl shadow-blue-900/5 border border-gray-100 overflow-hidden">
                    
                    <div class="bg-white border-b border-gray-50 px-8 py-6">
                        <h2 class="text-xl font-bold text-gray-800 flex items-center gap-3">
                            <i class="fa fa-building text-blue-500"></i> 
                            Данни за фирмата
                        </h2>
                        <p class="text-gray-400 text-sm mt-1">Въведете ЕИК, за да попълним данните автоматично.</p>
                    </div>

                    <form id="company-form" class="p-4">
                        {# Preloader #}
                        <div id="preloader" class="rounded-3xl">
                            <div class="flex flex-col items-center gap-4">
                                <div class="loader-circle"></div>
                                <span class="text-blue-600 font-bold animate-pulse text-sm">Търсене в Търговски регистър...</span>
                            </div>
                        </div>

                        <div id="alert-container" class="fixed top-5 right-5 z-[9999] w-80 space-y-2"></div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            
                            <div class="md:col-span-2 lg:col-span-1">
                                <label for="eik" class="block text-sm font-bold text-gray-700 mb-2 ml-1">ЕИК / БУЛСТАТ</label>
                                <div class="relative group">
                                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-gray-400 group-focus-within:text-blue-500 transition-colors">
                                        <i class="fa fa-search text-lg"></i>
                                    </div>
                                    <input type="text" id="eik" name="eik" placeholder="Въведете 9 цифри..." maxlength="18" autocomplete="off" 
                                           class="w-full bg-gray-50 border border-gray-200 rounded-2xl py-2 pl-12 pr-12 focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 focus:bg-white transition-all outline-none font-medium">
                                    <div class="absolute inset-y-0 right-0 pr-4 flex items-center">
                                        <i class="fa fa-check-circle success-tick text-green-500 text-xl" style="display: none;"></i>
                                    </div>
                                </div>
                                <p id="error-eik" class="text-red-500 text-xs font-bold mt-2 ml-1"></p>
                            </div>

                            <div class="hidden lg:block"></div> <div class="md:col-span-2">
                                <label for="company" class="block text-sm font-bold text-gray-700 mb-2 ml-1">Име на фирмата</label>
                                <input type="text" id="company" name="company" placeholder="Име на фирма..." 
                                       class="w-full bg-gray-50 border border-gray-200 rounded-2xl py-2 px-5 focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 focus:bg-white transition-all outline-none font-medium">
                                <p id="error-company" class="text-red-500 text-xs font-bold mt-2 ml-1"></p>
                            </div>

                            <div>
                                <label for="city" class="block text-sm font-bold text-gray-700 mb-2 ml-1">Град</label>
                                <input type="text" id="city" name="city" placeholder="Град" 
                                       class="w-full bg-gray-50 border border-gray-200 rounded-2xl py-2 px-5 focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 focus:bg-white transition-all outline-none font-medium">
                                <p id="error-city" class="text-red-500 text-xs font-bold mt-2 ml-1"></p>
                            </div>

                            <div>
                                <label for="district" class="block text-sm font-bold text-gray-700 mb-2 ml-1">Район</label>
                                <input type="text" id="district" name="district" placeholder="Район" 
                                       class="w-full bg-gray-50 border border-gray-200 rounded-2xl py-2 px-5 focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 focus:bg-white transition-all outline-none font-medium">
                                <p id="error-district" class="text-red-500 text-xs font-bold mt-2 ml-1"></p>
                            </div>

                            <div>
                                <label for="manager" class="block text-sm font-bold text-gray-700 mb-2 ml-1">Управител</label>
                                <input type="text" id="manager" name="manager" placeholder="Имена на управител" 
                                       class="w-full bg-gray-50 border border-gray-200 rounded-2xl py-2 px-5 focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 focus:bg-white transition-all outline-none font-medium">
                                <p id="error-manager" class="text-red-500 text-xs font-bold mt-2 ml-1"></p>
                            </div>

                            <div class="md:col-span-2">
                                <label for="address" class="block text-sm font-bold text-gray-700 mb-2 ml-1">Адрес на регистрация</label>
                                <input type="text" id="address" name="address" placeholder="ул. Примерна №10..." 
                                       class="w-full bg-gray-50 border border-gray-200 rounded-2xl py-2 px-5 focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 focus:bg-white transition-all outline-none font-medium">
                                <p id="error-address" class="text-red-500 text-xs font-bold mt-2 ml-1"></p>
                            </div>
                        </div>

                        <input type="hidden" id="eik_token" name="eik_token" value="{{ eik_token }}">
                        <div style="display:none;">
                            <input type="text" id="subject_line" name="subject_line" tabindex="-1" autocomplete="off">
                        </div>

                        <div class="mt-10 flex flex-col items-center">
                            <button type="button" id="submit-btn" class="w-full md:w-auto min-w-[200px] bg-blue-600 hover:bg-blue-700 text-white text-lg font-bold py-4 px-12 rounded-2xl shadow-lg shadow-blue-200 hover:-translate-y-1 transition-all active:scale-95">
                                Изпрати данните
                            </button>
                            <p class="text-gray-400 text-xs mt-4 italic">Всички данни се обработват съгласно ЗЗЛД.</p>
                        </div>
                    </form>
                </div>
            </div>

            {{ column_right }}
        </div>
    </div>
</div>

<style>
#preloader {
    display: none;
    position: absolute;
    inset: 0;
    background: rgba(255,255,255,0.9);
    z-index: 50;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(4px);
}
.loader-circle {
    border: 6px solid #f3f3f3;
    border-top: 6px solid #2563eb;
    border-radius: 50%;
    width: 60px;
    height: 60px;
    animation: spin 1s linear infinite;
}
@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
.is-valid { border-color: #10b981 !important; background-color: #f0fdf4 !important; }
.alert-box { animation: slideIn 0.3s ease-out; }
@keyframes slideIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
</style>

<script>



/* -------------------------------------------------------
   EIK input handler
------------------------------------------------------- */
let lastLoadedEik = '';
let eikTimer = null;

$('#eik').on('input', function () {

    var raw = $(this).val();
    var eik = normalizeEik(raw);

    clearTimeout(eikTimer);

    if (eik.length === 9) {
       
        eikTimer = setTimeout(function() {
            loadCompany(eik);
        }, 400); 
    } else {
        lastLoadedEik = '';
        $('#company, #city, #district, #address, #manager').val('');
    }

});


/* -------------------------------------------------------
   Normalize EIK
------------------------------------------------------- */
function normalizeEik(value){

    if(!value) return '';

    value = value.trim();
    value = value.replace(/^bg/i,''); 
    value = value.replace(/\D/g,'');

    return value;
}


/* -------------------------------------------------------
   Load company from API
------------------------------------------------------- */


function loadCompany(eik) {

    var eikField = $('#eik');
    var preloader = $('#preloader');

     if (eik === lastLoadedEik) {
        return;
    }

    $.ajax({
        url: 'index.php?route=catalog/company/eik&eik_token=' +
             encodeURIComponent($('#eik_token').val()) +
             '&eik=' + encodeURIComponent(eik),

        dataType: 'json',

        beforeSend: function () {
            
            preloader.css('display', 'flex');
            eikField.prop('readonly', true);
        },

        success: function (json) {

            setTimeout(function () {

                preloader.hide();
                eikField.prop('readonly', false);

                if (json.error) {
                  
                    return;
                }

                $('#company, #city, #district, #address, #manager').val('');

                $('#company').val(json.name);
                $('#city').val(json.city);
                $('#district').val(json.district);
                $('#address').val(json.address);
                $('#manager').val(json.manager);

                lastLoadedEik = eik;

            }, 500);

        },

        error: function () {

            setTimeout(function () {

                preloader.hide();
                eikField.prop('readonly', false);

            }, 500);

        },

    });

}

function showNotification(message, type = 'success') {
    const color = (type === 'success') ? '#d4edda' : '#f8d7da';
    const textColor = (type === 'success') ? '#155724' : '#dd4b59';
    const borderColor = (type === 'success') ? '#c3e6cb' : '#f5c6cb';

    const html = `
        <div class="alert-box" style="background:${color}; color:${textColor}; border:1px solid ${borderColor}; padding:15px; border-radius:5px; margin-bottom:10px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); transition: opacity 0.5s ease;">
            <strong>${type === 'success' ? 'Успех!' : 'Грешка!'}</strong> ${message}
        </div>
    `;

    const $msg = $(html).appendTo('#alert-container');

  
    setTimeout(function() {
        $msg.css('opacity', '0'); // Fade out effect
        setTimeout(function() { $msg.remove(); }, 500); 
    }, 3000);
}


/* -------------------------------------------------------
   Submit form
------------------------------------------------------- */
$('#submit-btn').on('click', function () {
    console.log("Click detected! Starting validation...");
    $.ajax({

        url: 'index.php?route=catalog/company/submit&eik_token=' +
             encodeURIComponent($('#eik_token').val()),

        type: 'post',
        dataType: 'json',

        data: {

            eik:          $('#eik').val(),
            company:      $('#company').val(),
            city:         $('#city').val(),
            district:     $('#district').val(),
            address:      $('#address').val(),
            manager:      $('#manager').val(),
            token:        $('#eik_token').val(),
            subject_line: $('#subject_line').val()
        },

        success: function (json) {

            $('.text-danger').text('');
            $('.form-control').css('border-color', '#ccc');

            if (json.errors) {

                $.each(json.errors, function (key, message) {

                    $('#error-' + key).text(message);
                    $('#' + key).css('border-color', 'red');

                });
                if (typeof showNotification === "function") {
                    showNotification('Моля, попълнете правилно всички полета.', 'error');
                }
            }

            if (json.success) {

                if (typeof showNotification === "function") {
                    showNotification(json.success, 'success');
                }
                // Clear the form
                $('#company-form')[0].reset();
                lastLoadedEik = '';

            }

        },

        error: function(xhr, ajaxOptions, thrownError) {
            if (typeof showNotification === "function") {
                showNotification('Грешка при изпращане на данните. Моля, опитайте отново.', 'error');
            }
            console.log(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
        }
    });

});
</script>

        </div>

        {{ column_right }}

    </div>

</div>
{{ footer }}
