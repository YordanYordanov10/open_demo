<div id="cart" class="relative inline-block w-full">
  <button type="button" data-toggle="dropdown" 
          class="flex items-center justify-between w-full bg-blue-600 hover:bg-blue-700 text-white px-5 py-3 rounded-2xl shadow-md transition-all group">
    <div class="flex items-center gap-3">
        <i class="fa fa-shopping-basket text-xl group-hover:scale-110 transition-transform"></i>
        <span id="cart-total" class="text-sm font-semibold tracking-tight">{{ text_items }}</span>
    </div>
    <i class="fa fa-chevron-down text-[10px] opacity-70"></i>
  </button>
  
  <ul class="dropdown-menu absolute right-0 mt-2 w-80 bg-white shadow-2xl rounded-2xl border border-gray-100 hidden z-[100] p-4">
    {% if products or vouchers %}
        <li class="max-h-60 overflow-y-auto mb-4">
            <table class="w-full text-sm">
                {% for product in products %}
                <tr class="border-b border-gray-50 last:border-0">
                    <td class="py-3 w-12 text-center">
                        {% if product.thumb %}
                            <a href="{{ product.href }}"><img src="{{ product.thumb }}" alt="{{ product.name }}" title="{{ product.name }}" class="rounded-lg border border-gray-100" /></a>
                        {% endif %}
                    </td>
                    <td class="py-3 px-3">
                        <a href="{{ product.href }}" class="font-medium text-gray-800 hover:text-blue-600 block leading-tight">{{ product.name }}</a>
                        <span class="text-gray-500 text-xs">{{ product.quantity }} x {{ product.total }}</span>
                    </td>
                    <td class="py-3 text-right">
                        <button type="button" onclick="cart.remove('{{ product.cart_id }}');" title="{{ button_remove }}" class="text-gray-300 hover:text-red-500 transition-colors">
                            <i class="fa fa-times-circle"></i>
                        </button>
                    </td>
                </tr>
                {% endfor %}
            </table>
        </li>
        
        <li>
            <div class="bg-gray-50 rounded-xl p-3 mb-4">
                {% for total in totals %}
                <div class="flex justify-between text-sm py-1">
                    <span class="text-gray-600">{{ total.title }}:</span>
                    <span class="font-bold text-gray-900">{{ total.text }}</span>
                </div>
                {% endfor %}
            </div>
            <div class="grid grid-cols-2 gap-3">
                <a href="{{ cart }}" class="bg-gray-100 text-gray-700 text-center py-2.5 rounded-xl font-semibold text-sm hover:bg-gray-200 transition-colors">
                    <i class="fa fa-shopping-cart"></i> {{ text_cart }}
                </a>
                <a href="{{ checkout }}" class="bg-blue-600 text-white text-center py-2.5 rounded-xl font-semibold text-sm hover:bg-blue-700 transition-colors">
                    <i class="fa fa-share"></i> {{ text_checkout }}
                </a>
            </div>
        </li>
    {% else %}
        <li class="py-8 text-center">
            <div class="text-gray-200 mb-2">
                <i class="fa fa-shopping-basket text-4xl"></i>
            </div>
            <p class="text-gray-500 font-medium">{{ text_empty }}</p>
        </li>
    {% endif %}
  </ul>
</div>